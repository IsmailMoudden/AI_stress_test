# Application
APP_ENV=local
APP_NAME=scenario-workbench
LOG_LEVEL=INFO

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg://scenario_workbench:scenario_workbench@localhost:5432/scenario_workbench
REDIS_URL=redis://localhost:6379/0

# Azure
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_KEY_VAULT_URL=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# LLM Gateway
LLM_PROVIDER=openrouter
LLM_MODEL=openrouter/auto
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2
LLM_WEB_SEARCH_ENABLED=true
LLM_WEB_MAX_RESULTS=5
OPENROUTER_API_KEY=

# Governance
AUDIT_LOG_RETENTION_DAYS=2555
